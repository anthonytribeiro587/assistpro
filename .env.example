NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
ASSISTPRO_COMPANY_ID=

NEXT_PUBLIC_APP_URL=
WHATSAPP_WEBHOOK_SECRET=
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=
EVOLUTION_INSTANCE_NAME=

# Quando estas duas variáveis estiverem configuradas, o n8n assume o atendimento.
# Sem elas, o AssistPro usa apenas as regras seguras de contingência.
N8N_WEBHOOK_URL=
N8N_WEBHOOK_SECRET=

# Modelo de linguagem. Gemini é a opção planejada para o fluxo principal.
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Alternativa para linguagem e/ou transcrição de áudio.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe

# Resposta em áudio com voz autorizada do cliente.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=eleven_flash_v2_5
